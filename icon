<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <radialGradient id="sky" cx="50%" cy="30%" r="70%">
      <stop offset="0%" stop-color="#87e8f5"/>
      <stop offset="45%" stop-color="#3ab8d4"/>
      <stop offset="100%" stop-color="#0e6e8c"/>
    </radialGradient>
    <radialGradient id="ocean" cx="50%" cy="0%" r="100%">
      <stop offset="0%" stop-color="#22c9e0"/>
      <stop offset="100%" stop-color="#0a4a6a"/>
    </radialGradient>
    <radialGradient id="sun-glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#ffe866"/>
      <stop offset="60%" stop-color="#ffc845"/>
      <stop offset="100%" stop-color="#ff9a00" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="volcano-body" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#2d5a3d"/>
      <stop offset="100%" stop-color="#1a3d28"/>
    </linearGradient>
    <linearGradient id="volcano-snow" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#e8f4f0"/>
      <stop offset="100%" stop-color="#c8e8e0"/>
    </linearGradient>
    <linearGradient id="lava" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ff6b00"/>
      <stop offset="100%" stop-color="#cc2200"/>
    </linearGradient>
    <linearGradient id="lagon" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#22c9e0"/>
      <stop offset="100%" stop-color="#06b6d4"/>
    </linearGradient>
    <clipPath id="round">
      <rect width="512" height="512" rx="112"/>
    </clipPath>
    <filter id="glow">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- App icon rounded rect background -->

  <rect width="512" height="512" rx="112" fill="url(#sky)"/>

  <!-- Ocean / lagon base -->

  <ellipse cx="256" cy="490" rx="340" ry="120" fill="url(#ocean)"/>

  <!-- Lagon turquoise band -->

  <ellipse cx="256" cy="430" rx="280" ry="55" fill="url(#lagon)" opacity=".7"/>

  <!-- Sun glow halo -->

  <circle cx="256" cy="110" r="80" fill="url(#sun-glow)" opacity=".6"/>

  <!-- Sun -->

  <circle cx="256" cy="110" r="36" fill="#ffe866" filter="url(#glow)"/>
  <!-- Sun rays -->
  <g stroke="#ffc845" stroke-width="3.5" stroke-linecap="round" opacity=".8">
    <line x1="256" y1="60" x2="256" y2="42"/>
    <line x1="256" y1="160" x2="256" y2="178"/>
    <line x1="206" y1="110" x2="188" y2="110"/>
    <line x1="306" y1="110" x2="324" y2="110"/>
    <line x1="221" y1="75" x2="209" y2="63"/>
    <line x1="291" y1="145" x2="303" y2="157"/>
    <line x1="291" y1="75" x2="303" y2="63"/>
    <line x1="221" y1="145" x2="209" y2="157"/>
  </g>

  <!-- Main volcano (Piton des Neiges) -->

  <polygon points="256,168 132,420 380,420" fill="url(#volcano-body)"/>
  <!-- Snow cap -->
  <polygon points="256,168 222,232 290,232" fill="url(#volcano-snow)" opacity=".9"/>
  <!-- Ridge shading -->
  <polygon points="256,168 132,420 200,420" fill="rgba(0,0,0,.12)"/>

  <!-- Right smaller volcano (Fournaise) -->

  <polygon points="390,240 318,420 462,420" fill="#1e4a2e"/>
  <!-- Fournaise lava glow at top -->
  <circle cx="390" cy="238" r="14" fill="#ff4400" filter="url(#glow)" opacity=".9"/>
  <circle cx="390" cy="238" r="7" fill="#ffaa00"/>
  <!-- Lava drip -->
  <path d="M390 245 Q398 270 394 300 Q392 315 396 330" stroke="#ff5500" stroke-width="4" fill="none" stroke-linecap="round" opacity=".8"/>

  <!-- Left palm tree -->

  <rect x="86" y="310" width="9" height="95" rx="4" fill="#5a3a1a" transform="rotate(-6,90,405)"/>
  <text x="58" y="318" font-size="52" opacity=".95" transform="rotate(-8,85,310)">🌴</text>

  <!-- Right small palm -->

  <rect x="400" y="340" width="7" height="70" rx="3" fill="#5a3a1a" transform="rotate(5,403,410)"/>
  <text x="376" y="348" font-size="38" opacity=".85" transform="rotate(6,395,340)">🌴</text>

  <!-- Wave lines on ocean -->

  <g stroke="rgba(255,255,255,.25)" stroke-width="2.5" stroke-linecap="round" fill="none">
    <path d="M80 440 Q120 432 160 440 Q200 448 240 440"/>
    <path d="M270 445 Q310 437 350 445 Q390 453 430 445"/>
    <path d="M100 462 Q150 454 200 462 Q250 470 300 462"/>
  </g>

  <!-- "974" label at bottom -->

  <rect x="176" y="460" width="160" height="36" rx="18" fill="rgba(0,0,0,.35)"/>
  <text x="256" y="484" font-family="'Plus Jakarta Sans', sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle" letter-spacing="3">9 7 4</text>

</svg>
